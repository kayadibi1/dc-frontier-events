# Caddy site block for the calendar subdomain (events.emersus.ai).
# Append this to /etc/caddy/Caddyfile (or drop in /etc/caddy/Caddyfile.d/ if your
# setup imports that). Caddy auto-provisions a Let's Encrypt cert for the domain,
# so the .ics URL is HTTPS — which Google Calendar requires.
#
# This mirrors the live config: the signup form posts to /api/*, which Caddy
# reverse-proxies to the local subscribe service; security headers are applied;
# the email dry-run dir is hidden. The web root is whatever SITE_DIR the systemd
# timer builds into. Access logging is on, with the ?token= value redacted so
# stable subscriber tokens never land in the logs. A basic-auth-gated /ops path
# serves the private GoAccess visitor report (tools/ops_report.sh).

(security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		-Server
		-X-Powered-By
	}
}

events.emersus.ai {
	import security_headers

	# Access log. The query filter redacts ?token=... so the stable subscriber
	# unsub/preferences/calendar tokens are never written to disk.
	log {
		output file /var/log/caddy/events-access.log {
			roll_size 10MiB
			roll_keep 5
		}
		format filter {
			wrap json
			request>uri query {
				replace token REDACTED
			}
		}
	}

	# Signup API (double opt-in) -> the local subscribe service on :8810.
	# Without this, the landing-page signup form 404s.
	handle /api/* {
		reverse_proxy 127.0.0.1:8810
	}

	# Private ops dashboard (GoAccess visitor report), basic-auth gated.
	# Set the hash on the box with `caddy hash-password` -- do NOT commit the real
	# hash (this repo is public). Report is regenerated by tools/ops_report.sh.
	handle /ops* {
		basic_auth {
			sidar <BCRYPT-HASH-SET-ON-BOX>
		}
		root * /opt/dc-frontier-events/ops
		rewrite * /visitors.html
		file_server
	}

	root * /var/www/events.emersus.ai
	encode gzip

	# Serve .ics as a calendar (some clients are picky about the type).
	@ics path *.ics
	header @ics Content-Type "text/calendar; charset=utf-8"

	# Don't expose the email dry-run dir (out/email/*.eml).
	@email path /email /email/*
	respond @email 404

	file_server
}
